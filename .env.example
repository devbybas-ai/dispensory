# Database
DATABASE_URL=postgresql://dispensory_user:password@localhost:5432/dispensory

# Environment
NODE_ENV=development

# Auth
AUTH_SECRET=generate-a-random-string-at-least-32-characters

# Redis
REDIS_URL=redis://localhost:6379

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Dispensory

# S3-compatible storage (optional in dev)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# Email - Resend (optional in dev)
# RESEND_API_KEY=
# EMAIL_FROM=Dispensory <notifications@dispensory.example>

# SMS - Twilio (optional in dev)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Real-time (optional in dev)
# SOCKET_PORT=3001
# NEXT_PUBLIC_SOCKET_URL=ws://localhost:3001

# Maps (optional in dev)
# MAPS_API_KEY=
